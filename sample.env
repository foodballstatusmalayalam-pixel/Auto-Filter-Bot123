# ═══════════════════════════════════════════════════════════════════════════════
#  ⚡ TRINITY MODS · TRINITY AUTOFILTER — sample environment file.
#  Copy to ".env" (or set these on your hosting platform) and fill them in.
#  🔴 = required.  Crafted by Trinity Mods (@trinityXmods).
#  Source: github.com/Trinity-Mods/Auto-Filter-Bot · credit license-locked.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Telegram (🔴 required) ──
API_ID=
API_HASH=
BOT_TOKEN=

# ── Admins / channels ──
ADMINS=                      # space-separated user ids (🔴 at least one)
CHANNELS=                    # space-separated channels to auto-index
LOG_CHANNEL=                 # -100... log channel id (🔴 bot must be admin)
AUTH_CHANNEL=                # force-sub channel id(s), space-separated, 0=off
SUPPORT_CHAT=                # support username WITHOUT @
GRP_LNK=
CHNL_LNK=
OWNER_USER_NAME=

# ── MongoDB (🔴 required) ──
DATABASE_URI=
DATABASE_NAME=TrinityFilter
COLLECTION_NAME=Trinity_files

# ── Streaming (optional) ──
BIN_CHANNEL=                 # channel id storing streamed files
TMSL=                        # Trinity Mods Streaming Link — public domain WITHOUT https:// and /
PORT=8080
MULTI_TOKEN1=                # optional extra worker bot tokens
# MULTI_TOKEN2=

# ── Search / UX toggles ──
IMDB=False
SPELL_CHECK_REPLY=True
USE_CAPTION_FILTER=True
PM_FILTER=True
AUTO_FFILTER=True
MAX_BTN=True
SINGLE_BUTTON=True
INSIGHTS_MODE=True

# ── Auto-delete ──
AUTO_FILE_DELETE=True
AUTO_DELETE_TIME=600

# ── Limits / premium / referral ──
LIMIT_MODE=False
DAILY_FILE_LIMIT=5
DAILY_SENDALL_LIMIT=2
TRIAL_TIME=300
USER_POINT=50
REFERAL_USER_TIME=2592000
PREMIUM_LOGS=0

# ── Verification (token / shortener gates) ──
IS_VERIFY=False
VERIFY_SECRET=change-me-to-a-long-random-string
VERIFY_URL=
VERIFY_API=
TUTORIAL=

# ── Stream shortener (optional) ──
STREAM_MODE=False
STREAM_SITE=
STREAM_API=
STREAMHTO=

# ── Misc ──
TIMEZONE=Asia/Kolkata
SPELL_TIMEOUT=60
